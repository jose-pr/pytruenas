from __future__ import annotations

from pytruenas import Namespace as _NS
from pytruenas.models import jsonschema as _jsonschema
import typing as _ty

{%- set typeddicts = {} -%}

{% for qn in ns.namespaces() %}
from .{{ qn.pyname.relative_to(ns.pyname) }} import {{ qn.classname }}
{%- endfor %}


class {{ ns.classname }}(_NS):
    {% for qn in ns.methods() %}
    def {{ qn.pyname.name }}(self,
        {%- for decl in qn.declared_parameters(typeddicts) %}
        {{ decl }},
        {%- endfor %}
    ) -> {{ qn.returns.type_def(typeddicts) }}:
        """{{ docstring(qn.doc) }}"""
        ...
    {%- endfor %}
    {%- for qn in ns.namespaces() %}
    {{ qn.pyname.name }}: {{ qn.classname }}
    {%- endfor %}
    {%- if not ns.methods() and not ns.namespaces() %}
    pass
    {%- endif %}

{% for name, properties in typeddicts.items() %}
{{ name }} = _ty.TypedDict('{{ name }}', {
{%- for prop, typedef in properties.items() %}
    {{ prop | tojson }}: {{ typedef }},
{%- endfor %}
})
{% endfor %}
